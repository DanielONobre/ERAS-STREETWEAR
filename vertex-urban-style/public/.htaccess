<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Redireciona para HTTPS em produção
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove www (ou adicione www — escolha um padrão)
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

    # Lida com Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redireciona trailing slash
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Roda todas as requisições pelo index.php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ── Compressão Gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml font/ttf font/otf font/woff font/woff2
</IfModule>

# ── Cache de assets estáticos ─────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Imagens
    ExpiresByType image/jpeg     "access plus 1 year"
    ExpiresByType image/webp     "access plus 1 year"
    ExpiresByType image/png      "access plus 1 year"
    ExpiresByType image/gif      "access plus 1 year"
    ExpiresByType image/svg+xml  "access plus 1 month"
    ExpiresByType image/x-icon   "access plus 1 year"

    # Fontes
    ExpiresByType font/ttf       "access plus 1 year"
    ExpiresByType font/otf       "access plus 1 year"
    ExpiresByType font/woff      "access plus 1 year"
    ExpiresByType font/woff2     "access plus 1 year"

    # CSS e JS (versionados pelo Vite — hash no nome)
    ExpiresByType text/css                    "access plus 1 year"
    ExpiresByType application/javascript      "access plus 1 year"
    ExpiresByType application/x-javascript    "access plus 1 year"

    # HTML — sem cache (conteúdo dinâmico)
    ExpiresByType text/html      "access plus 0 seconds"
</IfModule>

# ── Headers de cache para Vite build ─────────────────────────────────────────
<IfModule mod_headers.c>
    # Assets com hash no nome: cache longo
    <FilesMatch "\.(js|css|woff2?|ttf|otf|svg|webp|png|jpg|gif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML sem cache
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # Remove X-Powered-By
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ── Segurança ─────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Impede clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Impede MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
</IfModule>

# Bloqueia acesso a arquivos sensíveis
<FilesMatch "(\.env|\.git|composer\.json|composer\.lock|package\.json|package-lock\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>
